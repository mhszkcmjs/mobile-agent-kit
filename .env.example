# ──────────────────────────────────────────────────────────────────────
# 这是一个示例文件，请勿在这里填真实密钥。
#
# 推荐做法（密钥不进项目目录、不可能被误推）：
#   Windows  : 复制本文件到 %USERPROFILE%\.config\mobile-agent\.env
#   macOS/Linux: 复制本文件到 ~/.config/mobile-agent/.env
#
# 或者通过环境变量指向任意路径：
#   $env:MOBILE_AGENT_ENV_FILE = "D:\secrets\mobile-agent.env"  (PowerShell)
#   export MOBILE_AGENT_ENV_FILE=/path/to/.env                  (bash)
#
# 兼容做法：项目根直接放 .env（已在 .gitignore 中），但不推荐。
# ──────────────────────────────────────────────────────────────────────

# Kimi (Moonshot) API
MOONSHOT_API_KEY=sk-your-moonshot-api-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 模型 ID（首次部署时跑 scripts/verify_kimi_model.py 实测后填入）
# 实测可用：moonshot-v1-32k / moonshot-v1-32k-vision-preview
MODEL_NAME=moonshot-v1-32k
VISION_MODEL_NAME=moonshot-v1-32k-vision-preview

# 终端编码(防 Windows 中文乱码)
PYTHONUTF8=1

# 设备(可选;为空时自动选 adb devices 第一个)
ANDROID_SERIAL=

# 调试日志级别
LOG_LEVEL=INFO
